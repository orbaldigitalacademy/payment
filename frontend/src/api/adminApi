import api from "./axios";

/**
 * LOGIN ADMIN
 */
export const adminLogin =
  async (credentials) => {
    const response =
      await api.post(
        "api/auth/login",
        credentials
      );

    if (
      response.data.token
    ) {
      localStorage.setItem(
        "token",
        response.data.token
      );
    }

    return response.data;
  };

/**
 * LOGOUT
 */
export const adminLogout =
  () => {
    localStorage.removeItem(
      "token"
    );
  };

/**
 * GET DASHBOARD STATS
 */
export const getDashboardStats =
  async () => {
    const response =
      await api.get(
        "/admin/dashboard",
        {
          headers: {
            Authorization: `Bearer ${localStorage.getItem(
              "token"
            )}`,
          },
        }
      );

    return response.data;
  };

